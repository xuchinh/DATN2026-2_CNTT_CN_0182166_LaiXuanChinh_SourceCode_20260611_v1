# ===== Cau hinh Backend (NestJS) =====
# Copy file nay thanh .env va dien gia tri thuc te truoc khi chay

# Cong server lang nghe (vi du: 8080)
PORT=cong_chay_server

# Chuoi ket noi MongoDB (vi du: mongodb://localhost:27017/roomhub)
MONGODB_URI=chuoi_ket_noi_mongodb

# Khoa bi mat de ky JWT
JWT_SECRET=khoa_bi_mat_jwt

# Thoi gian het han access token (vi du: 1d, 3600s)
JWT_ACCESS_TOKEN_EXPIRED=thoi_gian_het_han_token

# Email dung de gui thong bao / xac thuc
MAIL_USER=email_gui_thong_bao

# Mat khau ung dung cua email (app password)
MAIL_PASSWORD=mat_khau_ung_dung_email
