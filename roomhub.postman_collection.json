{
  "info": {
    "name": "RoomHub API",
    "description": "DATN - Hệ thống quản lý phòng trọ RoomHub\nBase URL: http://localhost:8080\n\nHướng dẫn:\n1. Chạy [Auth] Login trước\n2. Token tự lưu vào {{token}}\n3. Các ID tự lưu sau mỗi request Create",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "buildingId", "value": "", "type": "string" },
    { "key": "roomId", "value": "", "type": "string" },
    { "key": "packageId", "value": "", "type": "string" },
    { "key": "featureId", "value": "", "type": "string" },
    { "key": "reviewId", "value": "", "type": "string" },
    { "key": "blogId", "value": "", "type": "string" },
    { "key": "vehicleId", "value": "", "type": "string" },
    { "key": "electricityBillId", "value": "", "type": "string" },
    { "key": "waterBillId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Nguyễn Văn A\",\n  \"email\": \"nguyenvana@gmail.com\",\n  \"password\": \"123456\",\n  \"phone\": \"0901234567\",\n  \"address\": \"123 Đường ABC, Q.1, TP.HCM\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('token', res.data.access_token);",
                  "  console.log('✅ Token saved');",
                  "}",
                  "if (res.data && res.data.user && res.data.user._id) {",
                  "  pm.collectionVariables.set('userId', res.data.user._id);",
                  "  console.log('✅ UserId saved:', res.data.user._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"username\": \"nguyenvana@gmail.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Verify Account (Check Code)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/check-code",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "check-code"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"_id\": \"{{userId}}\",\n  \"code\": \"PASTE_CODE_FROM_EMAIL\"\n}"
            }
          }
        },
        {
          "name": "Retry Active (Gửi lại email xác thực)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/retry-active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "retry-active"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"nguyenvana@gmail.com\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password (Gửi email đặt lại)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/retry-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "retry-password"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"nguyenvana@gmail.com\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "change-password"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"nguyenvana@gmail.com\",\n  \"code\": \"PASTE_CODE_FROM_EMAIL\",\n  \"password\": \"newpass123\",\n  \"confirmPassword\": \"newpass123\"\n}"
            }
          }
        }
      ]
    },
