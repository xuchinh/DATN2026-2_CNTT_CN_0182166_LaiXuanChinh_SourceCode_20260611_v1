# ===== Cau hinh Frontend (Next.js) =====
# Copy file nay thanh .env va dien gia tri thuc te truoc khi chay

# Khoa bi mat cho NextAuth (chuoi ngau nhien dai)
NEXTAUTH_SECRET=khoa_bi_mat_nextauth

# Duong dan ung dung frontend (vi du: http://localhost:3000)
NEXTAUTH_URL=duong_dan_ung_dung_frontend

# Tuy chon cho Node (vi du: --max-old-space-size=4096)
NODE_OPTIONS=tuy_chon_node
